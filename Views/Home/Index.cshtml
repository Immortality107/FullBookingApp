@{
    ViewData["Title"] = "🌸 Lilium";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

<style>
    body {
        font-family: 'Segoe UI', sans-serif;
        background-color: #fdf6f9;
    }

    .lilium-container {
        padding: 40px 20px;
        text-align: center;
    }

    .lilium-title {
        font-weight: 600;
        font-size: 2.5rem;
        color: #aa336a;
        margin-bottom: 20px;
    }

    .lilium-image {
        max-width: 100%;
        height: auto;
        border-radius: 20px;
        margin-bottom: 30px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    }

    .lilium-button {
        margin: 10px;
        padding: 12px 24px;
        border-radius: 30px;
        border: none;
        background-color: #d96c9c;
        color: white;
        font-size: 1rem;
        transition: background-color 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

        .lilium-button:hover {
            background-color: #b24c7d;
        }

    hr.styled {
        border: none;
        height: 2px;
        background-color: #e8b2c5;
        margin: 40px auto;
        width: 80%;
    }

    #locationPopup {
        display: none;
        justify-content: center;
        align-items: center;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.6);
        z-index: 1000;
    }
</style>

<div class="lilium-container">
    <h1 class="lilium-title">Welcome to Lilium 🌸 Asmaa Kamel</h1>

    <img src="~/LiliumCover.jpg" alt="Lilium Cover" class="lilium-image" />

    <a href="#" class="lilium-button" onclick="showLocationPopup()">Book A Private Appointment</a>
    <a href="#" class="lilium-button" onclick="showLocationPopup()">Book A Support Circle (Women Only)</a>

    @Html.Partial("_PartialViewChooseLocation")
</div>

<hr class="styled" />

<h2 class="text-center text-muted">Reviews</h2>

<hr class="styled" />

<script>
    function showLocationPopup() {
        document.getElementById('locationPopup').style.display = 'flex';
    }

    function goToPage() {
        const selectedLocation = document.getElementById('countrySelect').value;
        if (!selectedLocation) {
            alert("Please select a location.");
            return;
        }
        switch (selectedLocation) {
            case 'Egypt':
                window.location.href = "Home/LocalChooseSession";
                break;
            default:
                window.location.href = "Home/InternationalChooseSession";
                break;
        }
    }
</script>
